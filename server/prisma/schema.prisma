generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique
  passwordHash      String
  role              String
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  requests          Request[] @relation("RequestCreatedBy")
  assignedRequests  Request[] @relation("RequestAssignedTo")
}

model Request {
  id                        String    @id @default(cuid())
  companyName               String
  contactPerson             String
  phoneNumber               String
  emailAddress              String
  title                     String
  status                    String
  dateFrom                  DateTime
  dateTo                    DateTime
  peopleCount               Int
  locationCity              String
  locationZIPcode           String
  locationStreet            String
  distanceFromDestinationKm Int
  budget                    Int
  mustHave                  String
  niceToHave                String
  furtherInformation        String
  createdAt                 DateTime  @default(now())
  lastUpdated               DateTime  @updatedAt
  createdById               String
  assignedToId              String?
  createdBy                 User      @relation("RequestCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  assignedTo                User?     @relation("RequestAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
}